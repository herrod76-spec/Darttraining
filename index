    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800;900&display=swap');
        :root { --bg: #030712; --card: #0f172a; --accent: #3b82f6; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: #f8fafc; height: 100vh; overflow: hidden; margin: 0; }
        
        .glass-card { background: #0f172a; border: 1px solid rgba(255,255,255,0.05); border-radius: 40px; }
