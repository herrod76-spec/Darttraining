    <script>
        let app = {
            numP: 1, players: ["Ich"], curP: 0,
            mode: null, scores: [], stats: [], logic: {},
            autodarts: { connected: false }
        };

        const $ = id => document.getElementById(id);

        function showView(v) {
            $('view-menu').classList.toggle('hidden', v !== 'menu');
            $('view-game').classList.toggle('hidden', v !== 'game');
            $('view-settings').classList.toggle('hidden', v !== 'settings');
        }

        function initSetup() {
            let hP = "";
            for(let i=1; i<=4; i++) hP += `<button onclick="setPC(${i})" class="w-14 h-14 rounded-2xl font-black text-xl transition-all ${i===app.numP?'bg-blue-600 text-white shadow-lg shadow-blue-600/20':'bg-slate-800 text-slate-500'}">${i}</button>`;
            $('pc-btns').innerHTML = hP;
            let hI = "";
            for(let i=0; i<app.numP; i++) {
                if(!app.players[i]) app.players[i] = "Spieler " + (i+1);
                hI += `<input type="text" value="${app.players[i]}" oninput="app.players[${i}]=this.value" class="bg-slate-800/50 p-5 rounded-2xl outline-none focus:ring-2 ring-blue-500 font-bold border border-white/5">`;
            }
            $('pn-inputs').innerHTML = hI;
        }

        function setPC(n) { app.numP = n; initSetup(); }

        function initGame(mode) {
            app.mode = mode; app.curP = 0;
            app.scores = Array(app.numP).fill(0);
            app.stats = Array(app.numP).fill(0).map(() => ({ r: 0, d: 0, h: 0, peak: 0 }));

            if(mode === '501') app.scores.fill(501);
            else if(mode === 'ladder50') { app.scores.fill(50); app.stats.forEach(s => s.peak = 50); }
            else if(mode === 'bob27') { app.scores.fill(27); app.logic = { target: 1 }; }
            else if(mode === 'jdc') { app.scores.fill(0); app.logic = { step: 0, targets: [10,11,12,13,14,15,"D-RND",16,17,18,19,20,"T-RND",25] }; }
            else if(mode === 'cricket') {
                app.logic = { nums: [20,19,18,17,16,15,25], state: Array(app.numP).fill(0).map(() => ({ 20:0, 19:0, 18:0, 17:0, 16:0, 15:0, 25:0 })) };
            }
            showView('game');
            updateUI();
        }

        function updateUI() {
            const p = app.curP; const m = app.mode; const sc = app.scores[p];
            $('ui-mode-badge').innerText = m.replace('_', ' ');
            $('ui-player').innerText = app.players[p];
            $('ui-main').innerText = sc;
            
            let area = $('input-area');
            let grid = $('cricket-grid');
            grid.classList.add('hidden');
            $('ui-helper-box').classList.remove('hidden');

            if(m === '501') {
                $('ui-helper').innerText = getCO(sc);
                area.innerHTML = `<input type="number" id="val" class="bg-slate-800 p-10 rounded-[32px] text-7xl font-900 text-center outline-none w-full border-2 border-white/5 focus:border-blue-500/50" placeholder="0" autofocus>
                                  <button onclick="do501()" class="bg-blue-600 py-8 rounded-[32px] font-900 text-2xl uppercase w-full shadow-2xl shadow-blue-900/20">Wurf bestätigen</button>`;
            } else if(m === 'ladder50') {
                $('ui-helper').innerText = "Ziel: D" + (sc/2);
                area.innerHTML = `<div class="grid grid-cols-2 gap-6 h-40">
                    <button onclick="doLadder(true)" class="bg-emerald-600 rounded-[32px] font-900 text-2xl uppercase shadow-lg shadow-emerald-900/20">Checkout ✅</button>
                    <button onclick="doLadder(false)" class="bg-rose-600 rounded-[32px] font-900 text-2xl uppercase shadow-lg shadow-rose-900/20">Miss ❌</button>
                </div>`;
            } else if(m === 'cricket') {
                grid.classList.remove('hidden');
                $('ui-helper-box').classList.add('hidden');
                let hG = "";
                app.logic.nums.forEach(n => {
                    const hits = app.logic.state[p][n];
                    hG += `<div class="flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/5 ${hits>=3?'closed-num':''}">
                        <span class="font-900 w-16 text-2xl tracking-tighter">${n===25?'BULL':n}</span>
                        <div class="flex gap-3" onclick="hitCricket(${n})">
                            <div class="cricket-box ${hits>=1?'filled':''}"></div>
                            <div class="cricket-box ${hits>=2?'filled':''}"></div>
                            <div class="cricket-box ${hits>=3?'filled':''}"></div>
                        </div>
                        <button onclick="hitCricket(${n})" class="bg-blue-500/10 hover:bg-blue-500/20 w-14 h-14 rounded-xl font-black text-blue-400 transition-colors">+</button>
                    </div>`;
                });
                grid.innerHTML = hG;
                area.innerHTML = `<button onclick="nextRound()" class="bg-emerald-600 py-8 rounded-[32px] font-900 text-2xl uppercase w-full">Nächste Runde</button>`;
            } else if(m === 'bob27') {
                $('ui-helper').innerText = "Ziel: D" + app.logic.target;
                area.innerHTML = `<div class="grid grid-cols-3 gap-4">
                    <button onclick="doBob(0)" class="bg-rose-600 py-6 rounded-2xl font-black">0 Hits</button>
                    <button onclick="doBob(1)" class="bg-blue-600 py-6 rounded-2xl font-black">1 Hit</button>
                    <button onclick="doBob(2)" class="bg-emerald-600 py-6 rounded-2xl font-black">2+ Hits</button>
                </div>`;
            } else if(m === 'jdc') {
                let target = app.logic.targets[app.logic.step];
                $('ui-helper').innerText = "Ziel: " + target;
                area.innerHTML = `<input type="number" id="val" class="bg-slate-800 p-8 rounded-3xl text-6xl font-900 text-center outline-none w-full" placeholder="Score">
                                  <button onclick="doJDC()" class="bg-amber-600 py-6 rounded-3xl font-black text-xl uppercase w-full">Score Senden</button>`;
            }

            $('st-high').innerText = app.stats[p].peak || 0;
            $('st-rounds').innerText = app.stats[p].r;
            $('st-acc').innerText = getStat();
        }

        function do501() {
            const v = parseInt($('val').value) || 0; 
            if(app.scores[app.curP] - v >= 0) app.scores[app.curP] -= v;
            if(app.scores[app.curP] === 0) { alert("Sieg!"); showView('menu'); }
            else nextRound();
        }

        function doLadder(win) {
            if(win) { 
                app.scores[app.curP] += 5; 
                app.stats[app.curP].h++;
                if(app.scores[app.curP] > app.stats[app.curP].peak) app.stats[app.curP].peak = app.scores[app.curP];
            } else { 
                app.scores[app.curP] = Math.max(2, app.scores[app.curP] - 1); 
            }
            nextRound();
        }

        function doBob(hits) {
            let target = app.logic.target;
            if(hits === 0) app.scores[app.curP] -= (target * 2);
            else app.scores[app.curP] += (target * 2 * hits);
            
            if(app.scores[app.curP] <= 0) { alert("Game Over!"); showView('menu'); return; }
            
            app.logic.target++;
            if(app.logic.target > 20) app.logic.target = 25; // Bullseye am Ende
            nextRound();
        }

        function hitCricket(n) {
            if(app.logic.state[app.curP][n] < 3) app.logic.state[app.curP][n]++;
            else { 
                if(!app.logic.state.every(s => s[n] >= 3)) app.scores[app.curP] += n; 
            }
            updateUI();
        }

        function nextRound() {
            app.stats[app.curP].r++; 
            app.curP = (app.curP + 1) % app.numP;
            updateUI();
        }

        function getStat() {
            const s = app.stats[app.curP];
            if(app.mode === 'ladder50') return s.r > 0 ? Math.round((s.h/s.r)*100) + "%" : "0%";
            if(app.mode === '501') return s.r > 0 ? (( (501 - app.scores[app.curP]) / (s.r * 3) ) * 3).toFixed(1) : "0.0";
            return "0.0";
        }

        function getCO(s) {
            const table = { 170:"T20 T20 BE", 167:"T20 T19 BE", 100:"T20 D20", 40:"D20", 32:"D16", 16:"D8", 8:"D4", 4:"D2", 2:"D1" };
            return table[s] || (s <= 170 ? "Finish " + s : "Scoring");
        }

        async function connectAutodarts() {
            // Logik-Platzhalter für WebSocket
            $('conn-status').innerHTML = '<div class="status-dot"></div> Verbinde...';
            setTimeout(() => {
                $('conn-status').classList.add('connected');
                $('global-status').classList.add('connected');
                $('conn-status').innerHTML = '<div class="status-dot"></div> Live';
                $('global-status').querySelector('span').innerText = "Autodarts Live";
            }, 1000);
        }

        initSetup();
    </script>
</body>
</html>

